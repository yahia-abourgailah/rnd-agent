# Copy to .env.dev and fill in. Load it with: ENV_FILE=.env.dev
# Local development on your own machine against the docker-compose services.

ENV=development
LOG_LEVEL=DEBUG

# --- Database (local docker-compose postgres) ---
DATABASE_URL=postgresql+psycopg://launch_intel:launch_intel@localhost:5432/launch_intel

# --- Redis / Celery (local docker-compose redis) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# --- LLM extraction (cheap model while iterating) ---
OPENAI_API_KEY=sk-...
EXTRACTION_MODEL=openai/gpt-4o-mini

# --- Slack (dev channel only — never the real one; notify is Phase 3) ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_ALERT_CHANNEL=#launch-alerts-dev

# --- Crawling (gentle: watch a demo source, slow rate) ---
# Neutral crawler identity; set a reachable contact address per the team's
# legal decision on crawling. Does not name the operating company.
USER_AGENT=MarketIntelBot/1.0 (+mailto:research-bot@example.com)
PLAYWRIGHT_HEADLESS=true
DEFAULT_REQUEST_TIMEOUT_SECONDS=30
DEFAULT_RATE_LIMIT_PER_HOST_SECONDS=2
