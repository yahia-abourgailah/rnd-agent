# Copy to .env and fill in real values. Never commit the real .env.

# --- Database ---
DATABASE_URL=postgresql+psycopg://launch_intel:launch_intel@localhost:5432/launch_intel

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# --- LLM extraction (Instructor) ---
OPENAI_API_KEY=sk-...
EXTRACTION_MODEL=openai/gpt-4o-mini

# --- Slack notifications (TODO: phase 3) ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_ALERT_CHANNEL=#launch-alerts

# --- Crawling ---
# Neutral crawler identity; set a reachable contact address per the team's
# legal decision on crawling. Does not name the operating company.
USER_AGENT=MarketIntelBot/1.0 (+mailto:research-bot@example.com)
PLAYWRIGHT_HEADLESS=true
DEFAULT_REQUEST_TIMEOUT_SECONDS=30
DEFAULT_RATE_LIMIT_PER_HOST_SECONDS=2

# --- App ---
ENV=development
LOG_LEVEL=INFO
