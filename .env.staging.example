# Template for the STAGING environment. In staging, prefer injecting these as
# real environment variables from your platform's secret store rather than a
# committed file. Load with: ENV_FILE=.env.staging (if using a file).
# Staging mirrors production infrastructure but with throwaway data.

ENV=staging
LOG_LEVEL=INFO

# --- Database (staging's OWN db — never points at prod) ---
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@staging-db.internal:5432/launch_intel

# --- Redis / Celery (staging's own instance) ---
REDIS_URL=redis://staging-redis.internal:6379/0
CELERY_BROKER_URL=redis://staging-redis.internal:6379/1

# --- LLM extraction (real model, low volume) ---
OPENAI_API_KEY=   # from secret store
EXTRACTION_MODEL=gpt-4o

# --- Slack (test channel, NOT the real R&D channel) ---
SLACK_BOT_TOKEN=  # from secret store
SLACK_ALERT_CHANNEL=#launch-alerts-staging

# --- Crawling ---
PLAYWRIGHT_HEADLESS=true
DEFAULT_REQUEST_TIMEOUT_SECONDS=30
DEFAULT_RATE_LIMIT_PER_HOST_SECONDS=2
