# Template for the PRODUCTION environment. Do NOT keep a real .env.production
# file on disk in prod — inject these as environment variables from your
# platform's secret manager (AWS/GCP Secrets Manager, K8s secrets, Railway/
# Render env vars, etc.). Settings reads env vars identically to a file.
# This file exists only to document what production requires.

ENV=production
LOG_LEVEL=INFO

# --- Database (production db — backed up, restricted access) ---
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@prod-db.internal:5432/launch_intel

# --- Redis / Celery ---
REDIS_URL=redis://prod-redis.internal:6379/0
CELERY_BROKER_URL=redis://prod-redis.internal:6379/1

# --- LLM extraction ---
OPENAI_API_KEY=   # from secret store — required
EXTRACTION_MODEL=gpt-4o

# --- Slack (the REAL R&D alert channel; notify is Phase 3) ---
SLACK_BOT_TOKEN=  # from secret store — required
SLACK_ALERT_CHANNEL=#launch-alerts

# --- Crawling ---
PLAYWRIGHT_HEADLESS=true
DEFAULT_REQUEST_TIMEOUT_SECONDS=30
DEFAULT_RATE_LIMIT_PER_HOST_SECONDS=2
